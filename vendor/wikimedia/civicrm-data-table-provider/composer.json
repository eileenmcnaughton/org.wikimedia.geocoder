{
    "name": "wikimedia/civicrm-data-table-provider",
    "type": "library",
    "description": "CiviCRM datatable geocoder",
    "keywords": [],
    "homepage": "http://geocoder-php.org/Geocoder/",
    "license": "MIT",
    "authors": [
        {
            "name": "Eileen McNaughton",
            "email": "emcnaughton@wikimedia.org"
        }
    ],
    "require": {
        "php": ">=8.2",
        "geocoder-php/common-http": "^4.5",
        "willdurand/geocoder": "^4|^5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "geocoder-php/provider-integration-tests": "^1.6",
        "php-http/curl-client": "^2.2"
    },
    "provide": {
        "geocoder-php/provider-implementation": "1.0"
    },
    "autoload": {
        "psr-4": { "Geocoder\\Provider\\DataTable\\": "" },
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-ci": "vendor/bin/phpunit --coverage-text --coverage-clover=build/coverage.xml"
    },
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-master": "4.0-dev"
        }
    },
    "config": {
	"platform": {
		"php": "8.2.26"
	},
	"allow-plugins": {
            "php-http/discovery": true
        }

    }
}
